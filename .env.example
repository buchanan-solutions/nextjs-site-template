# Application / System

SITE_DOMAIN=localhost
SITE_FQDN=http://localhost
HOST_PORT=80

# Strapi V5 CMS =======================================================================================================

# Server
HOST=0.0.0.0
PORT=1337
# NODE_ENV=development
NODE_ENV=production

# Secrets
APP_KEYS=key1,key2,key3
API_TOKEN_SALT=salt
ADMIN_JWT_SECRET=jwt-secret
TRANSFER_TOKEN_SALT=trx-token-salt
ENCRYPTION_KEY=encryption-key
JWT_SECRET=jwt-secret

# Database
# DATABASE_CLIENT=sqlite # sqlite, postgres
DATABASE_CLIENT=postgres

# Database - Postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi_admin
DATABASE_PASSWORD=password
DATABASE_SSL=false

STRAPI_WEBHOOK_SECRET=abc123

# NEXTJS Site =======================================================================================================

NEXT_PUBLIC_NODE_ENV=production

NEXT_TELEMETRY_DISABLED=1

NEXT_PUBLIC_API_VERSION=/v0

NEXT_PUBLIC_STRAPI_URL=https://cms.${SITE_DOMAIN}
STRAPI_CMS_API_URL=https://cms.${SITE_DOMAIN}
STRAPI_CMS_API_TOKEN=key

